<Window x:Class="Varyant1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Varyant1"
        mc:Ignorable="d"
        Title="Окно авторизации" MinHeight="350" MaxHeight="400" MinWidth="600" MaxWidth="650"
		WindowStartupLocation="CenterScreen">
    <Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="100"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="100"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="50"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="auto"/>
		</Grid.RowDefinitions>

		<Button x:Name="Exit"
			    Grid.Column="2" 
				Grid.Row="0" 
				FontWeight="Bold"
				Background="Red" 
				Foreground="White"
				HorizontalAlignment="Right"
				Width="40" 
				Height="25" 
				Content="X"
				FontSize="15"
				Margin="0,10,10,0"
				Click="Exit_Click">
		</Button>
		<TextBlock Grid.Column="1"
				   Grid.Row="1"
				   Text="Авторизация"
				   HorizontalAlignment="Center"
				   FontWeight="Bold"
				   FontSize="25">
		</TextBlock>
		<TextBlock Grid.Column="1"
				   Grid.Row="2"
				   Text="IdNumber:"
				   HorizontalAlignment="Left"
				   Margin="0,10"
				   FontSize="15">
		</TextBlock>
		<TextBox x:Name="IdNumber"
				 Grid.Column="1"
				 Grid.Row="3"
				 Height="25">
			
		</TextBox>
		<TextBlock Grid.Column="1"
				   Grid.Row="4"
				   Margin="0,10"
				   Text="Password:"
				   HorizontalAlignment="Left"
				   FontSize="15">
		</TextBlock>
		<PasswordBox x:Name="Password"
					 Grid.Column="1"
					 Grid.Row="5"
					 Height="25">
		</PasswordBox>
		<Button x:Name="Login"
				Grid.Column="1"
				Grid.Row="6"
				Height="40"
				Width="150"
				Margin="20"
				FontSize="15"
				Content="Войти"
				Background="LightBlue"
				Click="Login_Click">
		</Button>
	</Grid>
</Window>
