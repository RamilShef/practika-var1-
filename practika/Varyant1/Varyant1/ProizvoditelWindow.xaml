<Window x:Class="Varyant1.ProizvoditelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Varyant1"
        mc:Ignorable="d"
        Title="Окно производителя" MinHeight="350" MaxHeight="400" MinWidth="600" MaxWidth="650"
        WindowStartupLocation="CenterScreen">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="100"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="100"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="auto"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Column="1"
				   Grid.Row="0"
				   Text="Добро пожаловать!"
				   Margin="0,10"
				   HorizontalAlignment="Center"
				   FontWeight="Bold"
				   FontSize="25">
		</TextBlock>
		<StackPanel Grid.Column="1"
					Grid.Row="1"
					Margin="10"
					Orientation="Vertical"
					HorizontalAlignment="Center">
			<Button x:Name="Profil"
					Height="50"
					Width="200"
					Margin="0,10"
					FontSize="15"
					Content="Профиль"
					Background="LightBlue"
					Click="Profil_Click">
			</Button>
			<Button x:Name="Zayavki"
					Height="50"
					Width="200"
					Margin="0,10"
					FontSize="15"
					Content="Заявки"
					Background="LightBlue"
					Click="Zayavki_Click">
			</Button>
		</StackPanel>
		<Button x:Name="Exit"
				Grid.Column="1"
				Grid.Row="6"
				Height="40"
				Width="150"
				Margin="20"
				Content="Выход"
				FontSize="15"
				Foreground="White"
				HorizontalAlignment="Center"
				Background="Red"
				Click="Exit_Click">
		</Button>
	</Grid>
</Window>
